{
  "schemaVersion": "1.0",
  "modelType": "WORKFLOW_AST",
  "workflow": {
    "id": "leave-request-approval",
    "title": "Leave Request Approval",
    "description": "Employee submits a leave request. Manager and HR approvals determine the final outcome.",
    "language": "en",
    "domain": "hr",
    "sourceRequirement": "Employee submits a leave request. Manager approves or rejects it. If approved and the leave duration is more than 5 days, HR reviews it. If HR approves, the leave is confirmed. Otherwise, it is rejected."
  },
  "extensions": {
    "nodeKinds": [],
    "transitionKinds": []
  },
  "ast": {
    "actors": [
      {
        "id": "EMPLOYEE",
        "name": "Employee",
        "type": "USER"
      },
      {
        "id": "MANAGER",
        "name": "Manager",
        "type": "USER"
      },
      {
        "id": "HR",
        "name": "HR",
        "type": "ADMIN"
      },
      {
        "id": "SYSTEM",
        "name": "System",
        "type": "SYSTEM"
      }
    ],
    "variables": [],
    "nodes": [
      {
        "id": "N1",
        "role": "START",
        "kind": "START",
        "title": "Start"
      },
      {
        "id": "N2",
        "role": "INPUT",
        "kind": "SUBMIT_LEAVE_REQUEST",
        "title": "Employee submits leave request",
        "actorId": "EMPLOYEE"
      },
      {
        "id": "N3",
        "role": "DECISION",
        "kind": "MANAGER_DECISION",
        "title": "Manager decision",
        "actorId": "MANAGER"
      },
      {
        "id": "N4",
        "role": "DECISION",
        "kind": "CHECK_LEAVE_DURATION",
        "title": "Leave duration is more than 5 days?",
        "actorId": "SYSTEM"
      },
      {
        "id": "N5",
        "role": "DECISION",
