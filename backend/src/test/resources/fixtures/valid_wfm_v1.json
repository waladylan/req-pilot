        "title": "HR decision",
        "actorId": "HR"
      },
      {
        "id": "N6",
        "role": "OUTPUT",
        "kind": "CONFIRM_LEAVE",
        "title": "Leave is confirmed",
        "actorId": "SYSTEM"
      },
      {
        "id": "N7",
        "role": "OUTPUT",
        "kind": "REJECT_LEAVE",
        "title": "Leave is rejected",
        "actorId": "SYSTEM"
      },
      {
        "id": "N8",
        "role": "END",
        "kind": "END",
        "title": "End"
      }
    ],
    "transitions": [
      {
        "id": "T1",
        "from": "N1",
        "to": "N2",
        "semantic": "DEFAULT"
      },
      {
        "id": "T2",
        "from": "N2",
        "to": "N3",
        "semantic": "DEFAULT"
      },
      {
        "id": "T3",
        "from": "N3",
        "to": "N4",
        "semantic": "YES",
        "condition": "Manager approves"
      },
      {
        "id": "T4",
        "from": "N3",
        "to": "N7",
        "semantic": "NO",
        "condition": "Manager rejects"
      },
      {
        "id": "T5",
        "from": "N4",
        "to": "N5",
        "semantic": "YES",
        "condition": "Leave duration is more than 5 days"
      },
      {
        "id": "T6",
        "from": "N4",
        "to": "N6",
        "semantic": "NO",
        "condition": "Leave duration is 5 days or fewer"
      },
      {
        "id": "T7",
        "from": "N5",
        "to": "N6",
        "semantic": "YES",
        "condition": "HR approves"
      },
      {
        "id": "T8",
        "from": "N5",
        "to": "N7",
        "semantic": "NO",
        "condition": "HR rejects"
      },
      {
        "id": "T9",
        "from": "N6",
        "to": "N8",
